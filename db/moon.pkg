import {
  "oboard/morm",
  "oboard/morm/engine",
  "moonbitlang/core/json",
}

options(
  "pre-build": [
    {
      "command": "$mod_dir/.mooncakes/oboard/morm/morm-gen $input -o $output && moonfmt -w $output",
      "input": "message.mbt",
      "output": "message.g.mbt",
    },
    {
      "command": "$mod_dir/.mooncakes/oboard/morm/morm-gen $input -o $output && moonfmt -w $output",
      "input": "message_mapper.mbt",
      "output": "message_mapper.g.mbt",
    },
  ],
)
