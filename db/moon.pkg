import {
  "oboard/morm",
  "oboard/morm/engine" @morm/engine,
  "moonbitlang/core/json",
}

options(
  "pre-build": [
    {
      "command": "moon runwasm oboard/morm/mormgen $input -o $output && moonfmt -w $output",
      "input": "message.mbt",
      "output": "message.g.mbt",
    },
    {
      "command": "moon runwasm oboard/morm/mormgen $input -o $output && moonfmt -w $output",
      "input": "message_mapper.mbt",
      "output": "message_mapper.g.mbt",
    },
  ],
)
