// Success tests (no error expected)

test "conformance/0106: fass.de" {
  let result = @idna.to_ascii(
    "fass.de",
    use_std3_ascii_rules=false,
    check_hyphens=false,
    check_bidi=false,
    check_joiners=false,
    verify_dns_length=false,
  )
  assert_eq(result, "fass.de")
}

