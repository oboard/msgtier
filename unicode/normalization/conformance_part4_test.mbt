    assert_eq(nfkd_c3, c5, msg="NFKD(c3) != c5 at index \{i}")
    assert_eq(nfkd_c4, c5, msg="NFKD(c4) != c5 at index \{i}")
    assert_eq(nfkd_c5, c5, msg="NFKD(c5) != c5 at index \{i}")
  }
}
